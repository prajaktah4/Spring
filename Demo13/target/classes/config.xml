<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

	<!-- bean definitions here -->
	
	
	<bean id="Address" class="com.Entity.Address">
		<constructor-arg value="12345"></constructor-arg>
		<constructor-arg value="pune"></constructor-arg>
	</bean>
	

	<bean id="e" class="com.Entity.Employee" autowire="constructor" >
		<constructor-arg value="101"></constructor-arg>
		<constructor-arg value="prajakta"></constructor-arg>
		<constructor-arg value="1000.0"></constructor-arg>
		<constructor-arg ref="Address"></constructor-arg>
		
		
	</bean>

</beans>